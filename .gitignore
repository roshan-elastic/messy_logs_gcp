terraform.tfvars

# Terraform state (may contain secrets)
*.tfstate
*.tfstate.backup
.terraform.tfstate.lock.info

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

